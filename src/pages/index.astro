---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE, GITHUB_URL, LINKEDIN_URL, EMAIL, PHONE, CV_URL } from '../consts';
import { getCollection } from 'astro:content';

const featuredProjects = (await getCollection('projects'))
	.filter(p => p.data.featured)
	.map(p => p.data);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<p class="eyebrow">~/home</p>
				<h1>Itziar Morales Rodríguez</h1>
				<p class="tagline">Software Engineering Student · Data Science & AI Minor · Madrid, Spain</p>
				<p>
					I build data pipelines, machine learning systems, and backend APIs.
					Currently completing a B.S. in Software Engineering at U-tad, looking for a remote/hybrid
					data engineering or applied ML internship.
				</p>
				<div class="contact-bar">
					<a href={`mailto:${EMAIL}`} class="contact-item">
						<span class="contact-label">✉</span>
						{EMAIL}
					</a>
					<a href={`tel:${PHONE.replace(/\s/g, '')}`} class="contact-item">
						<span class="contact-label">✆</span>
						{PHONE}
					</a>
				</div>
				<nav class="links">
					<a href={GITHUB_URL} target="_blank" rel="noopener">GitHub</a>
					<a href={LINKEDIN_URL} target="_blank" rel="noopener">LinkedIn</a>
					<a href="/about">About</a>
					<a href="/projects">Projects</a>
					<a href={CV_URL} target="_blank" rel="noopener">Download CV</a>
				</nav>
			</section>

			<section class="projects" id="projects">
				<div class="section-heading">
					<div>
						<h2>Featured Projects</h2>
						<p>Selected projects below. Browse the full collection on the dedicated projects page.</p>
					</div>
					<a class="view-all" href="/projects">See all projects →</a>
				</div>

				{featuredProjects.map((project) => (
					<div class="project-card">
						<h3><a href={project.link} target="_blank" rel="noopener">{project.title}</a></h3>
						<p>{project.summary}</p>
						<p class="tech">{project.tech}</p>
						{project.blogSlug && (
							<a class="read-post" href={`/blog/${project.blogSlug}`}>Read post →</a>
						)}
					</div>
				))}
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.eyebrow {
		font-family: var(--font-mono);
		color: var(--accent);
		font-size: 0.85rem;
		margin-bottom: 0.4rem;
		margin-top: 0;
	}
	.contact-bar {
		display: flex;
		gap: 1.5rem;
		align-items: center;
		margin-bottom: 1rem;
		flex-wrap: wrap;
	}
	.contact-item {
		display: flex;
		align-items: center;
		gap: 0.4em;
		font-family: var(--font-mono);
		font-size: 0.85rem;
		color: var(--text-muted);
		text-decoration: none;
		transition: color 0.15s ease;
	}
	.contact-item:hover {
		color: var(--accent);
	}
	.contact-label {
		color: var(--accent);
	}
	.section-heading {
		display: flex;
		justify-content: space-between;
		align-items: end;
		gap: 1.5rem;
		margin-bottom: 1.5rem;
		flex-wrap: wrap;
	}
	.section-heading h2 {
		margin-bottom: 0.4rem;
	}
	.section-heading p {
		margin: 0;
		color: var(--text-muted);
		max-width: 40rem;
	}
	.view-all {
		color: var(--accent);
		text-decoration: none;
		font-weight: 600;
		white-space: nowrap;
	}
	.view-all:hover {
		text-decoration: underline;
	}
	.project-card h3 {
		margin-bottom: 0.4em;
	}
	.read-post {
		display: inline-block;
		margin-top: 0.4rem;
		font-size: 0.82rem;
		color: var(--text-muted);
		text-decoration: none;
		transition: color 0.15s ease;
	}
	.read-post:hover {
		color: var(--accent);
	}
</style>
