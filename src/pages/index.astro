---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE, GITHUB_URL, LINKEDIN_URL, EMAIL, PHONE, CV_URL } from '../consts';
import { getCollection } from 'astro:content';

const featuredProjects = (await getCollection('projects'))
	.filter(p => p.data.featured)
	.map(p => p.data);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<pre class="ascii-art" aria-hidden="true">┌─────────────────────────────┐
│  itziar@portfolio:~$ whoami │
│  > software engineer        │
│  > data science minor       │
│  > cello · C++ · Python     │
└─────────────────────────────┘</pre>
				<p class="eyebrow">~/home</p>
				<h1>Itziar Morales Rodríguez</h1>
				<p class="tagline">Software Engineering Student · Data Science & AI Minor · Madrid, Spain</p>
				<p class="personality">I write C++ game engines for fun, train neural nets for class, and run a home server I definitely don’t tinker with too much.</p>
				<p>
					I build data pipelines, machine learning systems, and backend APIs.
					Currently completing a B.S. in Software Engineering at U-tad, looking for a remote/hybrid
					data engineering or applied ML internship.
				</p>
				<div class="contact-bar">
					<a href={`mailto:${EMAIL}`} class="contact-item">
						<span class="contact-label">✉</span>
						{EMAIL}
					</a>
					<a href={`tel:${PHONE.replace(/\s/g, '')}`} class="contact-item">
						<span class="contact-label">✆</span>
						{PHONE}
					</a>
				</div>
				<nav class="links">
					<a href={GITHUB_URL} target="_blank" rel="noopener">GitHub</a>
					<a href={LINKEDIN_URL} target="_blank" rel="noopener">LinkedIn</a>
					<a href="/about">About</a>
					<a href="/projects">Projects</a>
					<a href={CV_URL} target="_blank" rel="noopener">Download CV</a>
				</nav>
			</section>

			<section class="projects" id="projects">
				<div class="section-heading">
					<div>
						<h2>Featured Projects</h2>
						<p>Selected projects below. Browse the full collection on the dedicated projects page.</p>
					</div>
					<a class="view-all" href="/projects">See all projects →</a>
				</div>

				{featuredProjects.map((project) => (
					<div class="proj-card">
						<a class="proj-card-inner" href={project.link} target="_blank" rel="noopener">
							<div class="tags">
								<span class="featured-badge">Featured</span>
								<span class={`origin origin-${project.origin.toLowerCase().replace(/[^a-z]/g, '')}`}>{project.origin}</span>
								{project.tags.map(tag => (
									<span class="tag">{tag}</span>
								))}
								{project.blogSlug && <span class="tag tag-post">Post ✏️</span>}
							</div>
							<h3>{project.title}</h3>
							<p class="summary">{project.summary}</p>
							<p class="tech">{project.tech}</p>
							<span class="card-cta">Open ↗</span>
						</a>
						{project.blogSlug && (
							<div class="card-footer">
								<a class="footer-link" href={`/blog/${project.blogSlug}`}>Read post →</a>
							</div>
						)}
					</div>
				))}
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	/* ASCII art block */
	.ascii-art {
		font-family: var(--font-mono);
		font-size: 0.78rem;
		line-height: 1.6;
		color: var(--text-muted);
		background: none;
		border: none;
		padding: 0;
		margin: 0 0 1.5rem 0;
		white-space: pre;
		pointer-events: none;
	}

	.eyebrow {
		font-family: var(--font-mono);
		color: var(--accent);
		font-size: 0.85rem;
		margin-bottom: 0.4rem;
		margin-top: 0;
	}

	.personality {
		color: var(--text-muted);
		font-size: 0.88em;
		margin-bottom: 0.75em;
		font-style: italic;
	}

	.contact-bar {
		display: flex;
		gap: 1.5rem;
		align-items: center;
		margin-bottom: 1rem;
		flex-wrap: wrap;
	}
	.contact-item {
		display: flex;
		align-items: center;
		gap: 0.4em;
		font-family: var(--font-mono);
		font-size: 0.85rem;
		color: var(--text-muted);
		text-decoration: none;
		transition: color 0.15s ease;
	}
	.contact-item:hover {
		color: var(--accent);
	}
	.contact-label {
		color: var(--accent);
	}
	.section-heading {
		display: flex;
		justify-content: space-between;
		align-items: end;
		gap: 1.5rem;
		margin-bottom: 1.5rem;
		flex-wrap: wrap;
	}
	.section-heading h2 {
		margin-bottom: 0.4rem;
	}
	.section-heading p {
		margin: 0;
		color: var(--text-muted);
		max-width: 40rem;
	}
	.view-all {
		color: var(--accent);
		text-decoration: none;
		font-weight: 600;
		white-space: nowrap;
	}
	.view-all:hover {
		text-decoration: underline;
	}

	/* Unified project cards — match projects page */
	.proj-card {
		display: flex;
		flex-direction: column;
		border: 1px solid var(--border);
		border-left: 3px solid var(--accent);
		border-radius: 6px;
		background: var(--surface);
		margin-bottom: 1rem;
		transition: border-color 0.15s ease, box-shadow 0.15s ease, transform 0.15s ease;
	}
	.proj-card:hover {
		border-color: var(--accent);
		box-shadow: 0 0 14px rgba(167, 139, 250, 0.1);
		transform: translateY(-2px);
	}
	.proj-card-inner {
		display: flex;
		flex-direction: column;
		padding: 1.25rem 1.25rem 0.75rem;
		text-decoration: none;
		gap: 0.4rem;
		flex: 1;
	}
	.proj-card h3 {
		font-size: 1rem;
		margin: 0;
		color: var(--accent);
	}
	.proj-card p {
		margin: 0;
		font-size: 0.88rem;
	}
	.proj-card .summary {
		color: var(--text);
	}
	.proj-card .tech {
		color: var(--text-muted);
		font-size: 0.78rem;
		margin-top: auto;
		padding-top: 0.5rem;
	}
	.card-cta {
		color: var(--accent);
		font-size: 0.82rem;
		font-weight: 600;
		margin-top: 0.5rem;
	}
	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.35rem;
		align-items: center;
	}
	.featured-badge {
		display: inline-block;
		font-size: 0.7rem;
		font-weight: 600;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		padding: 0.1em 0.45em;
		border-radius: 3px;
		background: rgba(167, 139, 250, 0.15);
		color: var(--accent);
		border: 1px solid rgba(167, 139, 250, 0.35);
	}
	.origin {
		display: inline-block;
		font-size: 0.7rem;
		font-weight: 600;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		padding: 0.1em 0.45em;
		border-radius: 3px;
	}
	.origin-personal {
		background: rgba(52, 211, 153, 0.1);
		color: #34d399;
		border: 1px solid rgba(52, 211, 153, 0.25);
	}
	.origin-utad {
		background: rgba(96, 165, 250, 0.1);
		color: #60a5fa;
		border: 1px solid rgba(96, 165, 250, 0.25);
	}
	.origin-digipen {
		background: rgba(251, 146, 60, 0.1);
		color: #fb923c;
		border: 1px solid rgba(251, 146, 60, 0.25);
	}
	.tag {
		font-size: 0.72rem;
		padding: 0.15em 0.55em;
		border-radius: 3px;
		background: rgba(167, 139, 250, 0.1);
		color: var(--accent);
		border: 1px solid rgba(167, 139, 250, 0.25);
		letter-spacing: 0.02em;
		font-weight: 500;
	}
	.tag-post {
		background: rgba(52, 211, 153, 0.08);
		color: #34d399;
		border-color: rgba(52, 211, 153, 0.25);
	}
	.card-footer {
		display: flex;
		border-top: 1px solid var(--border);
	}
	.footer-link {
		flex: 1;
		padding: 0.5rem 1.25rem;
		color: var(--text-muted);
		font-size: 0.78rem;
		text-decoration: none;
		transition: color 0.15s ease;
		text-align: center;
	}
	.footer-link:hover {
		color: var(--accent);
	}

	@media (max-width: 720px) {
		.ascii-art { font-size: 0.68rem; }
	}
</style>
