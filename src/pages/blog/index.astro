---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`Blog | ${SITE_TITLE}`}
			description="Writing on software engineering, data science, ML, and systems programming."
		/>
	</head>
	<body>
		<Header />
		<main>
			<section class="blog-page">
				<p class="eyebrow">~/blog</p>
				<h1>Blog</h1>
				<p class="intro">Writing on software engineering, data science, ML, and systems programming.</p>

				{posts.length === 0 && (
					<p class="empty">No posts yet. Check back soon.</p>
				)}

				<ul class="post-list">
					{posts.map((post) => (
						<li>
							<a href={`/blog/${post.id}/`} class="post-link">
								<div class="post-meta">
									<span class="post-date">
										<FormattedDate date={post.data.pubDate} />
									</span>
								</div>
								<h2 class="post-title">{post.data.title}</h2>
								<p class="post-description">{post.data.description}</p>
								<span class="post-cta">Read post →</span>
							</a>
						</li>
					))}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.blog-page {
		padding: 0 0 3rem;
	}
	.eyebrow {
		font-family: var(--font-mono);
		color: var(--accent);
		font-size: 0.85rem;
		margin-bottom: 0.4rem;
		margin-top: 0;
	}
	.intro {
		color: var(--text-muted);
		max-width: 42rem;
		margin-bottom: 2rem;
	}
	.empty {
		color: var(--text-muted);
		font-style: italic;
	}
	.post-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}
	.post-link {
		display: flex;
		flex-direction: column;
		gap: 0.35rem;
		padding: 1.25rem;
		border: 1px solid var(--border);
		border-left: 3px solid var(--accent);
		border-radius: 6px;
		background: var(--surface);
		text-decoration: none;
		transition: box-shadow 0.15s ease, transform 0.15s ease, border-color 0.15s ease;
	}
	.post-link:hover {
		border-color: var(--accent);
		box-shadow: 0 0 14px rgba(167, 139, 250, 0.1);
		transform: translateY(-2px);
	}
	.post-meta {
		display: flex;
		align-items: center;
		gap: 0.75rem;
	}
	.post-date {
		font-family: var(--font-mono);
		font-size: 0.78rem;
		color: var(--text-muted);
	}
	.post-title {
		font-size: 1.1rem;
		margin: 0;
		color: var(--accent);
		line-height: 1.3;
	}
	.post-description {
		margin: 0;
		font-size: 0.88rem;
		color: var(--text-muted);
		max-width: 60rem;
	}
	.post-cta {
		color: var(--accent);
		font-size: 0.82rem;
		font-weight: 600;
		margin-top: 0.25rem;
	}
</style>
