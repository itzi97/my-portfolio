---
import { getCollection, render } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

function readTime(body: string): string {
	const words = body.trim().split(/\s+/).length;
	const mins = Math.max(1, Math.round(words / 200));
	return `${mins} min read`;
}

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const [featured, ...rest] = posts;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`Blog | ${SITE_TITLE}`}
			description="Writing on software engineering, data science, ML, and systems programming."
		/>
	</head>
	<body>
		<Header />
		<main>
			<section class="blog-page">
				<p class="eyebrow">~/blog</p>
				<h1>Blog</h1>
				<p class="intro">Writing on software engineering, data science, ML, and systems programming.</p>

				{posts.length === 0 && (
					<p class="empty">No posts yet. Check back soon.</p>
				)}

				{featured && (
					<a href={`/blog/${featured.id}/`} class="featured-post">
						<div class="featured-label">Latest post</div>
						<div class="featured-meta">
							<span class="post-date">
								<FormattedDate date={featured.data.pubDate} />
							</span>
							<span class="read-time">{readTime(featured.body ?? '')}</span>
						</div>
						<h2 class="featured-title">{featured.data.title}</h2>
						<p class="featured-description">{featured.data.description}</p>
						<span class="post-cta">Read post →</span>
					</a>
				)}

				{rest.length > 0 && (
					<ul class="post-grid">
						{rest.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`} class="post-link">
									<div class="post-meta">
										<span class="post-date">
											<FormattedDate date={post.data.pubDate} />
										</span>
										<span class="read-time">{readTime(post.body ?? '')}</span>
									</div>
									<h2 class="post-title">{post.data.title}</h2>
									<p class="post-description">{post.data.description}</p>
									<span class="post-cta">Read post →</span>
								</a>
							</li>
						))}
					</ul>
				)}
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.blog-page {
		padding: 0 0 3rem;
	}
	.eyebrow {
		font-family: var(--font-mono);
		color: var(--accent);
		font-size: 0.85rem;
		margin-bottom: 0.4rem;
		margin-top: 0;
	}
	.intro {
		color: var(--text-muted);
		max-width: 42rem;
		margin-bottom: 2rem;
	}
	.empty {
		color: var(--text-muted);
		font-style: italic;
	}

	/* ── Featured post ── */
	.featured-post {
		display: flex;
		flex-direction: column;
		gap: 0.4rem;
		padding: 1.75rem 2rem;
		border: 1px solid var(--border);
		border-left: 4px solid var(--accent);
		border-radius: 8px;
		background: var(--surface);
		text-decoration: none;
		margin-bottom: 1.5rem;
		transition: box-shadow 0.15s ease, transform 0.15s ease;
	}
	.featured-post:hover {
		box-shadow: 0 0 20px rgba(167, 139, 250, 0.12);
		transform: translateY(-2px);
	}
	.featured-label {
		font-family: var(--font-mono);
		font-size: 0.75rem;
		color: var(--accent);
		text-transform: uppercase;
		letter-spacing: 0.08em;
		margin-bottom: 0.2rem;
	}
	.featured-meta {
		display: flex;
		align-items: center;
		gap: 0.75rem;
	}
	.featured-title {
		font-size: 1.4rem;
		margin: 0;
		color: var(--accent);
		line-height: 1.25;
	}
	.featured-description {
		margin: 0;
		font-size: 0.92rem;
		color: var(--text-muted);
		max-width: 72rem;
	}

	/* ── Grid ── */
	.post-grid {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1rem;
	}
	@media (max-width: 640px) {
		.post-grid {
			grid-template-columns: 1fr;
		}
	}
	.post-grid li {
		display: flex;
	}
	.post-link {
		display: flex;
		flex-direction: column;
		gap: 0.35rem;
		padding: 1.25rem;
		border: 1px solid var(--border);
		border-left: 3px solid var(--accent);
		border-radius: 6px;
		background: var(--surface);
		text-decoration: none;
		width: 100%;
		transition: box-shadow 0.15s ease, transform 0.15s ease;
	}
	.post-link:hover {
		border-color: var(--accent);
		box-shadow: 0 0 14px rgba(167, 139, 250, 0.1);
		transform: translateY(-2px);
	}
	.post-meta {
		display: flex;
		align-items: center;
		gap: 0.75rem;
	}
	.post-date {
		font-family: var(--font-mono);
		font-size: 0.78rem;
		color: var(--text-muted);
	}
	.read-time {
		font-family: var(--font-mono);
		font-size: 0.78rem;
		color: var(--text-muted);
		opacity: 0.7;
	}
	.read-time::before {
		content: '·';
		margin-right: 0.75rem;
	}
	.post-title {
		font-size: 1.05rem;
		margin: 0;
		color: var(--accent);
		line-height: 1.3;
	}
	.post-description {
		margin: 0;
		font-size: 0.85rem;
		color: var(--text-muted);
	}
	.post-cta {
		color: var(--accent);
		font-size: 0.82rem;
		font-weight: 600;
		margin-top: 0.25rem;
	}
</style>
