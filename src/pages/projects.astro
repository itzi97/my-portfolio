---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';

const projects = [
	// Machine Learning
	{
		title: 'Dogs vs Cats',
		link: 'https://www.kaggle.com/code/itzi97/u-tad-dogs-vs-cats',
		summary: 'Image classification using CNNs and transfer learning.',
		tech: 'Python · Keras · TensorFlow · transfer learning',
		highlight: 'Built and fine-tuned a deep learning image classifier.',
		tags: ['Machine Learning', 'Deep Learning'],
		origin: 'U-tad'
	},
	{
		title: 'Alphanumeric Classification',
		link: 'https://www.kaggle.com/code/itzi97/u-tad-alphanumeric-classification',
		summary: 'ML pipeline for classifying alphanumeric characters.',
		tech: 'Python · scikit-learn · data augmentation',
		highlight: 'Full workflow from preprocessing to evaluation.',
		tags: ['Machine Learning'],
		origin: 'U-tad'
	},
	{
		title: 'Spam Filtering',
		link: 'https://www.kaggle.com/code/itzi97/u-tad-spam-not-spam',
		summary: 'Text classification project for spam detection.',
		tech: 'Python · NLP preprocessing · sklearn · feature engineering',
		highlight: 'Practical text classification pipeline for message filtering.',
		tags: ['Machine Learning', 'NLP'],
		origin: 'U-tad'
	},
	// Data
	{
		title: 'Firearm Homicides vs Legislation',
		link: 'https://github.com/itzi97/DV_Tableau',
		summary: 'Tableau dashboard analysing firearm homicides in the US.',
		tech: 'Tableau · CSV & Excel data processing · data cleaning',
		highlight: 'Interactive visualizations for regional and temporal trends.',
		tags: ['Data Visualisation', 'Data Analysis'],
		origin: 'U-tad'
	},
	{
		title: 'Fitness Tracking Visualization',
		link: 'https://github.com/itzi97/DV_Python',
		summary: 'Personal fitness tracking visualizations built with Python.',
		tech: 'Python · pandas · matplotlib · seaborn · plotly · ipywidgets',
		highlight: 'Time-series analysis and customizable performance dashboards.',
		tags: ['Data Visualisation', 'Data Analysis'],
		origin: 'U-tad'
	},
	// Backend
	{
		title: 'Social Media Site ODM',
		link: 'https://github.com/itzi97/AD-ODM',
		summary: 'Object-document mapper for MongoDB and Redis implemented in Python.',
		tech: 'Python · pymongo · redis-py · custom serialization',
		highlight: 'Lightweight ODM features and examples for common patterns.',
		tags: ['Backend', 'Database'],
		origin: 'U-tad'
	},
	{
		title: 'BildyApp',
		link: 'https://github.com/itzi97/wpii-bildyapp',
		summary: 'Backend JavaScript app for a fictitious company managing clients, projects, and certifications.',
		tech: 'Node.js · Express · REST API · JWT · database integration',
		highlight: 'Role-based endpoints and CRUD for core business entities.',
		tags: ['Backend'],
		origin: 'U-tad'
	},
	{
		title: 'Distributed Systems Exercises',
		link: 'https://github.com/itzi97/DS_exercise1_fm',
		summary: 'C++ distributed systems exercises covering chat systems and database tutorials.',
		tech: 'C++ · Docker · Kubernetes · networking fundamentals',
		highlight: 'Hands-on exercises demonstrating concurrency, messaging, and containerized deployment.',
		tags: ['Backend', 'Systems'],
		origin: 'U-tad'
	},
	// Game Dev
	{
		title: '2D Game Engine',
		link: 'https://github.com/itzi97/engine2d',
		summary: 'Personal ongoing 2D game engine built from scratch.',
		tech: 'C++ · Lua · Sol2 · SDL3 · GLM · CMake · Tiled JSON',
		highlight: 'Writing a game engine from scratch as a personal hobby.',
		tags: ['Game Dev', 'Systems'],
		origin: 'Personal'
	},
	{
		title: '2D Game Engine (archived)',
		link: 'https://github.com/itzi97/engine2d-old',
		summary: 'Archived iteration of the 2D game engine — currently has more features than the active rewrite.',
		tech: 'C++ · Lua · Sol2 · SDL2 · GLM',
		highlight: 'Earlier version preserved as a reference; active development continues in engine2d.',
		tags: ['Game Dev', 'Systems'],
		origin: 'Personal'
	},
	{
		title: 'World of Traps',
		link: 'https://gitlab.com/asielorz/world-of-traps-speedrun-edition',
		summary: 'Speedrun edition of a DigiPen game, built by two college classmates on an engine made from scratch.',
		tech: 'C++ · CMake · Milkytracker',
		highlight: 'Contributed to a game built on a custom engine (freshman year project) including a basic soundtrack.',
		tags: ['Game Dev'],
		origin: 'DigiPen'
	},
	{
		title: 'DEV — OST',
		link: 'https://soundcloud.com/zesher/sets/dev-ost',
		summary: 'Original soundtrack for DEV, a DigiPen student game.',
		tech: 'Milkytracker',
		highlight: 'Layered soundtrack designed to mirror the game\'s progression — each track introduces a new element, culminating in the full arrangement.',
		tags: ['Game Dev', 'Audio'],
		origin: 'DigiPen'
	},
	// Other
	{
		title: 'Gateway Technologies',
		link: 'https://youtu.be/97gPVvl1paQ?si=dHPNczPRvvbmhAbH',
		summary: 'Stellaris video guide for Paradox Interactive.',
		tech: 'DaVinci Resolve · Adobe After Effects · Audacity · Adobe Photoshop',
		highlight: 'Presenting a videogame guide in an entertaining and infographic manner.',
		tags: ['Video Production'],
		origin: 'Personal'
	},
	{
		title: 'Portfolio Website',
		link: 'https://github.com/itzi97/my-portfolio',
		summary: 'This portfolio and blog website.',
		tech: 'Astro · JavaScript · CSS · Cloudflare',
		highlight: 'Designed and built from scratch.',
		tags: ['Web'],
		origin: 'Personal'
	},
	// Academic
	{
		title: 'AM-apuntes',
		link: 'https://github.com/itzi97/AM-apuntes',
		summary: 'Real Analysis I & II class notes with linked exercise repositories.',
		tech: 'LaTeX · Markdown',
		highlight: 'Structured mathematical notes and worked problems.',
		tags: ['Mathematics'],
		origin: 'U-tad'
	},
	{
		title: 'Vacumcite',
		link: 'https://github.com/itzi97/vacumcite',
		summary: 'UX design project for a COVID vaccination website.',
		tech: 'Figma · HTML · CSS prototyping',
		highlight: 'User flows and accessibility-focused design decisions.',
		tags: ['UX / Design'],
		origin: 'U-tad'
	}
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Projects | ${SITE_TITLE}`} description="A full collection of software engineering, data science, ML, and academic projects by Itziar Morales Rodríguez." />
	</head>
	<body>
		<Header />
		<main class="wide">
			<section class="projects-page">
				<p class="eyebrow">~/projects</p>
				<h1>All Projects</h1>
				<p class="intro">
					Software engineering, data science, ML, game dev, and academic projects.
					Each card links directly to the repository, notebook, or demo.
				</p>

				<div class="projects-grid">
					{projects.map((project) => (
						<a class="proj-card" href={project.link} target="_blank" rel="noopener">
							<div class="tags">
								{project.tags.map(tag => (
									<span class="tag">{tag}</span>
								))}
							</div>
							<h2>{project.title}</h2>
							<p class="summary">{project.summary}</p>
							<p class="highlight">{project.highlight}</p>
							<p class="tech">
								<span class={`origin origin-${project.origin.toLowerCase().replace(/[^a-z]/g, '')}`}>{project.origin}</span>
								{project.tech}
							</p>
							<span class="card-cta">Open ↗</span>
						</a>
					))}
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.projects-page {
		padding: 1rem 0 3rem;
	}
	.projects-page h1 {
		margin-bottom: 0.6rem;
	}
	.intro {
		color: var(--text-muted);
		max-width: 42rem;
		margin-bottom: 2rem;
	}
	.projects-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
		gap: 1rem;
	}
	.proj-card {
		display: flex;
		flex-direction: column;
		padding: 1.25rem;
		border: 1px solid var(--border);
		border-left: 3px solid var(--accent);
		border-radius: 6px;
		background: var(--surface);
		text-decoration: none;
		transition: border-color 0.15s ease, box-shadow 0.15s ease, transform 0.15s ease;
		gap: 0.4rem;
	}
	.proj-card:hover {
		border-color: var(--accent);
		box-shadow: 0 0 14px rgba(167, 139, 250, 0.1);
		transform: translateY(-2px);
	}
	.proj-card h2 {
		font-size: 1rem;
		margin: 0;
		color: var(--accent);
	}
	.proj-card p {
		margin: 0;
		font-size: 0.88rem;
	}
	.proj-card .summary {
		color: var(--text);
	}
	.proj-card .highlight {
		color: var(--text-muted);
		font-size: 0.82rem;
	}
	.proj-card .tech {
		color: var(--text-muted);
		font-size: 0.78rem;
		margin-top: auto;
		padding-top: 0.5rem;
		display: flex;
		align-items: center;
		gap: 0.4rem;
		flex-wrap: wrap;
	}
	.origin {
		font-size: 0.7rem;
		font-weight: 600;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		padding: 0.1em 0.45em;
		border-radius: 3px;
		flex-shrink: 0;
	}
	.origin-personal {
		background: rgba(52, 211, 153, 0.1);
		color: #34d399;
		border: 1px solid rgba(52, 211, 153, 0.25);
	}
	.origin-utad {
		background: rgba(96, 165, 250, 0.1);
		color: #60a5fa;
		border: 1px solid rgba(96, 165, 250, 0.25);
	}
	.origin-digipen {
		background: rgba(251, 146, 60, 0.1);
		color: #fb923c;
		border: 1px solid rgba(251, 146, 60, 0.25);
	}
	.card-cta {
		color: var(--accent);
		font-size: 0.82rem;
		font-weight: 600;
		margin-top: 0.5rem;
	}
	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.35rem;
		margin-bottom: 0.4rem;
	}
	.tag {
		font-size: 0.72rem;
		padding: 0.15em 0.55em;
		border-radius: 3px;
		background: rgba(167, 139, 250, 0.1);
		color: var(--accent);
		border: 1px solid rgba(167, 139, 250, 0.25);
		letter-spacing: 0.02em;
		font-weight: 500;
	}
</style>
