---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const projects = allProjects.map(p => p.data);

const featured = projects.filter(p => p.featured);
const rest = projects.filter(p => !p.featured);

const allTags = [...new Set(projects.flatMap(p => p.tags))].sort();
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Projects | ${SITE_TITLE}`} description="A full collection of software engineering, data science, ML, and academic projects by Itziar Morales Rodríguez." />
	</head>
	<body>
		<Header />
		<main class="wide">
			<section class="projects-page">
				<p class="eyebrow">~/projects</p>
				<h1>All Projects</h1>
				<p class="intro">
					Software engineering, data science, ML, game dev, and academic projects.
					Each card links directly to the repository, notebook, or demo.
				</p>

				<!-- Tag filter bar -->
				<div class="filter-bar">
					<button class="filter-pill active" data-tag="all">All</button>
					{allTags.map(tag => (
						<button class="filter-pill" data-tag={tag}>{tag}</button>
					))}
				</div>

				<!-- Featured projects -->
				{featured.length > 0 && (
					<div class="featured-grid" id="featured-section">
						{featured.map((project) => (
							<div class="proj-card proj-card--featured" data-tags={project.tags.join(',').toLowerCase()}>
								<a
									class="proj-card-inner"
									href={project.blogSlug ? `/blog/${project.blogSlug}` : project.link}
									target={project.blogSlug ? '_self' : '_blank'}
									rel={project.blogSlug ? undefined : 'noopener'}
								>
									<div class="tags">
										<span class="featured-badge">Featured</span>
										<span class={`origin origin-${project.origin.toLowerCase().replace(/[^a-z]/g, '')}`}>{project.origin}</span>
										{project.tags.map(tag => (
											<span class="tag">{tag}</span>
										))}
										{project.blogSlug && <span class="tag tag-post">Post ✏️</span>}
									</div>
									<h2>{project.title}</h2>
									<p class="summary">{project.summary}</p>
									<p class="highlight">{project.highlight}</p>
									<p class="tech">{project.tech}</p>
									<span class="card-cta">
										{project.blogSlug ? 'Read post →' : 'Open ↗'}
									</span>
								</a>
								{project.githubUrl && (
									<a class="github-link" href={project.githubUrl} target="_blank" rel="noopener">
										GitHub ↗
									</a>
								)}
							</div>
						))}
					</div>
				)}

				<!-- Rest of projects -->
				<div class="projects-grid" id="projects-grid">
					{rest.map((project) => (
						<div class="proj-card" data-tags={project.tags.join(',').toLowerCase()}>
							<a
								class="proj-card-inner"
								href={project.blogSlug ? `/blog/${project.blogSlug}` : project.link}
								target={project.blogSlug ? '_self' : '_blank'}
								rel={project.blogSlug ? undefined : 'noopener'}
							>
								<div class="tags">
									<span class={`origin origin-${project.origin.toLowerCase().replace(/[^a-z]/g, '')}`}>{project.origin}</span>
									{project.tags.map(tag => (
										<span class="tag">{tag}</span>
									))}
									{project.blogSlug && <span class="tag tag-post">Post ✏️</span>}
								</div>
								<h2>{project.title}</h2>
								<p class="summary">{project.summary}</p>
								<p class="highlight">{project.highlight}</p>
								<p class="tech">{project.tech}</p>
								<span class="card-cta">
									{project.blogSlug ? 'Read post →' : 'Open ↗'}
								</span>
							</a>
							{project.githubUrl && (
								<a class="github-link" href={project.githubUrl} target="_blank" rel="noopener">
									GitHub ↗
								</a>
							)}
						</div>
					))}
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<script>
	const pills = document.querySelectorAll<HTMLButtonElement>('.filter-pill');
	const featuredSection = document.getElementById('featured-section');
	const regularGrid = document.getElementById('projects-grid');

	// Keep track of each featured card's original home
	const featuredCards = featuredSection
		? Array.from(featuredSection.querySelectorAll<HTMLElement>('.proj-card--featured'))
		: [];

	function applyFilter(tag: string) {
		// First pass: decide visibility for every card everywhere
		const allCards = document.querySelectorAll<HTMLElement>('.proj-card');
		allCards.forEach(card => {
			const cardTags = card.dataset.tags ?? '';
			const visible = tag === 'all' || cardTags.split(',').includes(tag.toLowerCase());
			card.dataset.visible = visible ? 'true' : 'false';
		});

		// Count how many featured cards are visible
		const visibleFeatured = featuredCards.filter(c => c.dataset.visible === 'true');
		const useFeaturedLayout = visibleFeatured.length >= 2;

		if (useFeaturedLayout) {
			// Restore featured cards to their section
			featuredCards.forEach(card => {
				if (featuredSection && card.parentElement !== featuredSection) {
					featuredSection.appendChild(card);
				}
				card.classList.add('proj-card--featured');
				card.style.display = card.dataset.visible === 'true' ? '' : 'none';
			});
			if (featuredSection) featuredSection.style.display = '';
		} else {
			// Move all featured cards into the regular grid
			if (featuredSection) featuredSection.style.display = 'none';
			featuredCards.forEach(card => {
				if (regularGrid && card.parentElement !== regularGrid) {
					regularGrid.prepend(card);
				}
				card.classList.remove('proj-card--featured');
				card.style.display = card.dataset.visible === 'true' ? '' : 'none';
			});
		}

		// Show/hide regular grid cards
		if (regularGrid) {
			Array.from(regularGrid.querySelectorAll<HTMLElement>('.proj-card')).forEach(card => {
				card.style.display = card.dataset.visible === 'true' ? '' : 'none';
			});
			regularGrid.style.display = '';
		}
	}

	pills.forEach(pill => {
		pill.addEventListener('click', () => {
			pills.forEach(p => p.classList.remove('active'));
			pill.classList.add('active');
			applyFilter(pill.dataset.tag!);
		});
	});
</script>

<style>
	.projects-page {
		padding: 0 0 3rem;
	}
	.projects-page h1 {
		margin-bottom: 0.6rem;
	}
	.intro {
		color: var(--text-muted);
		max-width: 42rem;
		margin-bottom: 1.5rem;
	}

	/* Filter bar */
	.filter-bar {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
		margin-bottom: 1.75rem;
	}
	.filter-pill {
		font-size: 0.78rem;
		font-weight: 500;
		padding: 0.3em 0.85em;
		border-radius: 999px;
		border: 1px solid var(--border);
		background: transparent;
		color: var(--text-muted);
		cursor: pointer;
		transition: background 0.15s ease, color 0.15s ease, border-color 0.15s ease;
		font-family: inherit;
	}
	.filter-pill:hover {
		border-color: var(--accent);
		color: var(--accent);
	}
	.filter-pill.active {
		background: rgba(167, 139, 250, 0.12);
		border-color: var(--accent);
		color: var(--accent);
	}

	/* Featured grid — 2-col */
	.featured-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1rem;
		margin-bottom: 1rem;
	}
	@media (max-width: 640px) {
		.featured-grid {
			grid-template-columns: 1fr;
		}
	}

	/* Regular grid */
	.projects-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
		gap: 1rem;
	}

	/* Cards */
	.proj-card {
		display: flex;
		flex-direction: column;
		border: 1px solid var(--border);
		border-left: 3px solid var(--accent);
		border-radius: 6px;
		background: var(--surface);
		transition: border-color 0.15s ease, box-shadow 0.15s ease, transform 0.15s ease;
	}
	.proj-card:hover {
		border-color: var(--accent);
		box-shadow: 0 0 14px rgba(167, 139, 250, 0.1);
		transform: translateY(-2px);
	}
	.proj-card--featured {
		border-left-width: 4px;
	}
	.proj-card-inner {
		display: flex;
		flex-direction: column;
		padding: 1.25rem 1.25rem 0.75rem;
		text-decoration: none;
		gap: 0.4rem;
		flex: 1;
	}
	.proj-card--featured .proj-card-inner {
		padding: 1.5rem 1.75rem 1rem;
	}
	.proj-card h2 {
		font-size: 1rem;
		margin: 0;
		color: var(--accent);
	}
	.proj-card--featured h2 {
		font-size: 1.2rem;
	}
	.proj-card p {
		margin: 0;
		font-size: 0.88rem;
	}
	.proj-card .summary {
		color: var(--text);
	}
	.proj-card .highlight {
		color: var(--text-muted);
		font-size: 0.82rem;
	}
	.proj-card .tech {
		color: var(--text-muted);
		font-size: 0.78rem;
		margin-top: auto;
		padding-top: 0.5rem;
	}
	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.35rem;
		align-items: center;
	}
	.featured-badge {
		display: inline-block;
		font-size: 0.7rem;
		font-weight: 600;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		padding: 0.1em 0.45em;
		border-radius: 3px;
		background: rgba(167, 139, 250, 0.15);
		color: var(--accent);
		border: 1px solid rgba(167, 139, 250, 0.35);
	}
	.origin {
		display: inline-block;
		font-size: 0.7rem;
		font-weight: 600;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		padding: 0.1em 0.45em;
		border-radius: 3px;
	}
	.origin-personal {
		background: rgba(52, 211, 153, 0.1);
		color: #34d399;
		border: 1px solid rgba(52, 211, 153, 0.25);
	}
	.origin-utad {
		background: rgba(96, 165, 250, 0.1);
		color: #60a5fa;
		border: 1px solid rgba(96, 165, 250, 0.25);
	}
	.origin-digipen {
		background: rgba(251, 146, 60, 0.1);
		color: #fb923c;
		border: 1px solid rgba(251, 146, 60, 0.25);
	}
	.card-cta {
		color: var(--accent);
		font-size: 0.82rem;
		font-weight: 600;
		margin-top: 0.5rem;
	}
	.tag {
		font-size: 0.72rem;
		padding: 0.15em 0.55em;
		border-radius: 3px;
		background: rgba(167, 139, 250, 0.1);
		color: var(--accent);
		border: 1px solid rgba(167, 139, 250, 0.25);
		letter-spacing: 0.02em;
		font-weight: 500;
	}
	.tag-post {
		background: rgba(52, 211, 153, 0.08);
		color: #34d399;
		border-color: rgba(52, 211, 153, 0.25);
	}
	.github-link {
		display: block;
		padding: 0.5rem 1.25rem;
		border-top: 1px solid var(--border);
		color: var(--text-muted);
		font-size: 0.78rem;
		text-decoration: none;
		transition: color 0.15s ease;
	}
	.github-link:hover {
		color: var(--accent);
	}
</style>
