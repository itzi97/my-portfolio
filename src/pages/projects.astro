---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const projects = allProjects.map(p => p.data);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Projects | ${SITE_TITLE}`} description="A full collection of software engineering, data science, ML, and academic projects by Itziar Morales Rodríguez." />
	</head>
	<body>
		<Header />
		<main class="wide">
			<section class="projects-page">
				<p class="eyebrow">~/projects</p>
				<h1>All Projects</h1>
				<p class="intro">
					Software engineering, data science, ML, game dev, and academic projects.
					Each card links directly to the repository, notebook, or demo.
				</p>

				<div class="projects-grid">
					{projects.map((project) => (
						<a class="proj-card" href={project.link} target="_blank" rel="noopener">
							<div class="tags">
								<span class={`origin origin-${project.origin.toLowerCase().replace(/[^a-z]/g, '')}`}>{project.origin}</span>
								{project.tags.map(tag => (
									<span class="tag">{tag}</span>
								))}
							</div>
							<h2>{project.title}</h2>
							<p class="summary">{project.summary}</p>
							<p class="highlight">{project.highlight}</p>
							<p class="tech">{project.tech}</p>
							<span class="card-cta">Open ↗</span>
						</a>
					))}
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.projects-page {
		padding: 0 0 3rem;
	}
	.projects-page h1 {
		margin-bottom: 0.6rem;
	}
	.intro {
		color: var(--text-muted);
		max-width: 42rem;
		margin-bottom: 2rem;
	}
	.projects-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
		gap: 1rem;
	}
	.proj-card {
		display: flex;
		flex-direction: column;
		padding: 1.25rem;
		border: 1px solid var(--border);
		border-left: 3px solid var(--accent);
		border-radius: 6px;
		background: var(--surface);
		text-decoration: none;
		transition: border-color 0.15s ease, box-shadow 0.15s ease, transform 0.15s ease;
		gap: 0.4rem;
	}
	.proj-card:hover {
		border-color: var(--accent);
		box-shadow: 0 0 14px rgba(167, 139, 250, 0.1);
		transform: translateY(-2px);
	}
	.proj-card h2 {
		font-size: 1rem;
		margin: 0;
		color: var(--accent);
	}
	.proj-card p {
		margin: 0;
		font-size: 0.88rem;
	}
	.proj-card .summary {
		color: var(--text);
	}
	.proj-card .highlight {
		color: var(--text-muted);
		font-size: 0.82rem;
	}
	.proj-card .tech {
		color: var(--text-muted);
		font-size: 0.78rem;
		margin-top: auto;
		padding-top: 0.5rem;
	}
	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.35rem;
		align-items: center;
	}
	.origin {
		display: inline-block;
		font-size: 0.7rem;
		font-weight: 600;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		padding: 0.1em 0.45em;
		border-radius: 3px;
	}
	.origin-personal {
		background: rgba(52, 211, 153, 0.1);
		color: #34d399;
		border: 1px solid rgba(52, 211, 153, 0.25);
	}
	.origin-utad {
		background: rgba(96, 165, 250, 0.1);
		color: #60a5fa;
		border: 1px solid rgba(96, 165, 250, 0.25);
	}
	.origin-digipen {
		background: rgba(251, 146, 60, 0.1);
		color: #fb923c;
		border: 1px solid rgba(251, 146, 60, 0.25);
	}
	.card-cta {
		color: var(--accent);
		font-size: 0.82rem;
		font-weight: 600;
		margin-top: 0.5rem;
	}
	.tag {
		font-size: 0.72rem;
		padding: 0.15em 0.55em;
		border-radius: 3px;
		background: rgba(167, 139, 250, 0.1);
		color: var(--accent);
		border: 1px solid rgba(167, 139, 250, 0.25);
		letter-spacing: 0.02em;
		font-weight: 500;
	}
</style>
