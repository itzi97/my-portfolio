---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';

const projects = [
	{
		title: 'Dogs vs Cats',
		link: 'https://www.kaggle.com/code/itzi97/u-tad-dogs-vs-cats',
		summary: 'Image classification using CNNs and transfer learning.',
		tech: 'Keras · TensorFlow · Python · transfer learning',
		highlight: 'Built and fine-tuned a deep learning image classifier.',
		tags: ['Machine Learning', 'Deep Learning']
	},
	{
		title: 'Alphanumeric Classification',
		link: 'https://www.kaggle.com/code/itzi97/u-tad-alphanumeric-classification',
		summary: 'ML pipeline for classifying alphanumeric characters.',
		tech: 'Python · scikit-learn · data augmentation',
		highlight: 'Full workflow from preprocessing to evaluation.',
		tags: ['Machine Learning']
	},
	{
		title: 'Spam Filtering',
		link: 'https://www.kaggle.com/code/itzi97/u-tad-spam-not-spam',
		summary: 'Text classification project for spam detection.',
		tech: 'NLP preprocessing · sklearn · feature engineering',
		highlight: 'Practical text classification pipeline for message filtering.',
		tags: ['Machine Learning', 'NLP']
	},
	{
		title: 'DV_Tableau',
		link: 'https://github.com/itzi97/DV_Tableau',
		summary: 'Tableau dashboard analysing firearm homicides in the US.',
		tech: 'Tableau · CSV data processing · data cleaning',
		highlight: 'Interactive visualizations for regional and temporal trends.',
		tags: ['Data Visualisation', 'Data Analysis']
	},
	{
		title: 'DV_Python',
		link: 'https://github.com/itzi97/DV_Python',
		summary: 'Personal fitness tracking visualizations built with Python.',
		tech: 'Python · pandas · matplotlib · seaborn · plotly',
		highlight: 'Time-series analysis and customizable performance dashboards.',
		tags: ['Data Visualisation', 'Data Analysis']
	},
	{
		title: 'AD-ODM',
		link: 'https://github.com/itzi97/AD-ODM',
		summary: 'Object-document mapper for MongoDB and Redis implemented in Python.',
		tech: 'Python · pymongo · redis-py · custom serialization',
		highlight: 'Lightweight ODM features and examples for common patterns.',
		tags: ['Backend', 'Data Engineering']
	},
	{
		title: 'BildyApp',
		link: 'https://github.com/itzi97/wpii-bildyapp',
		summary: 'Backend REST API for a fictitious company managing clients, projects, and certifications.',
		tech: 'Node.js · Express · REST API · JWT · Docker',
		highlight: 'Role-based endpoints and CRUD for core business entities.',
		tags: ['Backend']
	},
	{
		title: 'Distributed Systems',
		link: 'https://github.com/itzi97/DS_exercise1_fm',
		summary: 'C++ distributed systems exercises covering chat systems and database tutorials.',
		tech: 'C++ · Docker · Kubernetes · networking fundamentals',
		highlight: 'Hands-on exercises demonstrating concurrency, messaging, and containerized deployment.',
		tags: ['Backend', 'Systems']
	},
	{
		title: 'AM-apuntes',
		link: 'https://github.com/itzi97/AM-apuntes',
		summary: 'Real Analysis I & II class notes with linked exercise repositories.',
		tech: 'LaTeX · Markdown',
		highlight: 'Structured mathematical notes and worked problems.',
		tags: ['Academic']
	},
	{
		title: 'vacumcite',
		link: 'https://github.com/itzi97/vacumcite',
		summary: 'UX design project for a COVID vaccination website.',
		tech: 'Figma · HTML · CSS prototyping',
		highlight: 'User flows and accessibility-focused design decisions.',
		tags: ['UX / Design']
	}
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Projects | ${SITE_TITLE}`} description="A full collection of software engineering, data science, ML, and academic projects by Itziar Morales Rodríguez." />
	</head>
	<body>
		<Header />
		<main class="wide">
			<section class="projects-page">
				<p class="eyebrow">~/projects</p>
				<h1>All Projects</h1>
				<p class="intro">
					Software engineering, data science, ML, dashboarding, and academic projects.
					Each card links directly to the repository or notebook.
				</p>

				<div class="projects-grid">
					{projects.map((project) => (
						<a class="proj-card" href={project.link} target="_blank" rel="noopener">
							<div class="tags">
								{project.tags.map(tag => (
									<span class="tag">{tag}</span>
								))}
							</div>
							<h2>{project.title}</h2>
							<p class="summary">{project.summary}</p>
							<p class="highlight">{project.highlight}</p>
							<p class="tech">{project.tech}</p>
							<span class="card-cta">Open ↗</span>
						</a>
					))}
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.projects-page {
		padding: 1rem 0 3rem;
	}
	.projects-page h1 {
		margin-bottom: 0.6rem;
	}
	.intro {
		color: var(--text-muted);
		max-width: 42rem;
		margin-bottom: 2rem;
	}
	.projects-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
		gap: 1rem;
	}
	.proj-card {
		display: flex;
		flex-direction: column;
		padding: 1.25rem;
		border: 1px solid var(--border);
		border-left: 3px solid var(--accent);
		border-radius: 6px;
		background: var(--surface);
		text-decoration: none;
		transition: border-color 0.15s ease, box-shadow 0.15s ease, transform 0.15s ease;
		gap: 0.4rem;
	}
	.proj-card:hover {
		border-color: var(--accent);
		box-shadow: 0 0 14px rgba(167, 139, 250, 0.1);
		transform: translateY(-2px);
	}
	.proj-card h2 {
		font-size: 1rem;
		margin: 0;
		color: var(--accent);
	}
	.proj-card p {
		margin: 0;
		font-size: 0.88rem;
	}
	.proj-card .summary {
		color: var(--text);
	}
	.proj-card .highlight {
		color: var(--text-muted);
		font-size: 0.82rem;
	}
	.proj-card .tech {
		color: var(--text-muted);
		font-size: 0.78rem;
		margin-top: auto;
		padding-top: 0.5rem;
	}
	.card-cta {
		color: var(--accent);
		font-size: 0.82rem;
		font-weight: 600;
		margin-top: 0.5rem;
	}
	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.35rem;
		margin-bottom: 0.4rem;
	}
	.tag {
		font-size: 0.72rem;
		padding: 0.15em 0.55em;
		border-radius: 3px;
		background: rgba(167, 139, 250, 0.1);
		color: var(--accent);
		border: 1px solid rgba(167, 139, 250, 0.25);
		letter-spacing: 0.02em;
		font-weight: 500;
	}
</style>
