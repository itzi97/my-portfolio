---
import PageLayout from '../layouts/PageLayout.astro';
import { SITE_TITLE } from '../consts';
import { Icon } from 'astro-icon/components';

const stack = [
	{
		category: 'Systems & Infrastructure',
		items: [
			{ name: 'C/C++', rating: 4, icon: 'simple-icons:cplusplus' },
			{ name: 'Linux', rating: 4, icon: 'simple-icons:linux' },
			{ name: 'Bash', rating: 3, icon: 'simple-icons:gnubash' },
			{ name: 'Distributed systems', rating: 3, icon: 'lucide:network' },
			{ name: 'Docker', rating: 3, icon: 'simple-icons:docker' },
			{ name: 'Rust', rating: 3, icon: 'simple-icons:rust' },
			{ name: 'AWS', rating: 3, icon: 'simple-icons:amazonwebservices' },
			{ name: 'Kubernetes', rating: 2, icon: 'simple-icons:kubernetes' },
		]
	},
	{
		category: 'Game Dev',
		items: [
			{ name: 'Game engine architecture', rating: 3, icon: 'lucide:cpu' },
			{ name: 'GLM', rating: 3, icon: 'lucide:box' },
			{ name: 'Graphics programming', rating: 3, icon: 'lucide:monitor' },
			{ name: 'Lua', rating: 3, icon: 'simple-icons:lua' },
			{ name: 'SDL2', rating: 3, icon: 'lucide:gamepad-2' },
			{ name: 'SDL3', rating: 3, icon: 'lucide:gamepad-2' },
			{ name: 'Sol2', rating: 3, icon: 'lucide:link' },
			{ name: 'OpenGL', rating: 1, icon: 'simple-icons:opengl' },
		]
	},
	{
		category: 'Web & Backend',
		items: [
			{ name: 'HTML / CSS', rating: 4, icon: 'simple-icons:html5' },
			{ name: 'JavaScript', rating: 3, icon: 'simple-icons:javascript' },
			{ name: 'Node.js / Express', rating: 3, icon: 'simple-icons:nodedotjs' },
			{ name: 'Golang', rating: 2, icon: 'simple-icons:go' },
			{ name: 'Zod', rating: 2, icon: 'simple-icons:zod' },
		]
	},
	{
		category: 'Databases',
		items: [
			{ name: 'MongoDB', rating: 4, icon: 'simple-icons:mongodb' },
			{ name: 'MariaDB', rating: 3, icon: 'simple-icons:mariadb' },
			{ name: 'PostgreSQL', rating: 3, icon: 'simple-icons:postgresql' },
			{ name: 'Redis', rating: 3, icon: 'simple-icons:redis' },
			{ name: 'Cassandra', rating: 2, icon: 'simple-icons:apachecassandra' },
			{ name: 'ChromaDB', rating: 2, icon: 'lucide:database' },
			{ name: 'Neo4j', rating: 2, icon: 'simple-icons:neo4j' },
		]
	},
	{
		category: 'Data & ML',
		items: [
			{ name: 'Pandas / Matplotlib / Seaborn', rating: 4, icon: 'simple-icons:pandas' },
			{ name: 'Python', rating: 4, icon: 'simple-icons:python' },
			{ name: 'Keras / TensorFlow', rating: 3, icon: 'simple-icons:keras' },
			{ name: 'Plotly / ipywidgets', rating: 3, icon: 'simple-icons:plotly' },
			{ name: 'scikit-learn', rating: 3, icon: 'simple-icons:scikitlearn' },
			{ name: 'Spark / Scala', rating: 3, icon: 'simple-icons:apachespark' },
			{ name: 'BeautifulSoup / Selenium', rating: 2, icon: 'simple-icons:selenium' },
		]
	},
	{
		category: 'Tools & Workflow',
		items: [
			{ name: 'Git', rating: 4, icon: 'simple-icons:git' },
			{ name: 'LaTeX', rating: 4, icon: 'simple-icons:latex' },
			{ name: 'CMake', rating: 3, icon: 'simple-icons:cmake' },
			{ name: 'DaVinci Resolve / After Effects', rating: 3, icon: 'simple-icons:davinciresolve' },
			{ name: 'Vim', rating: 3, icon: 'simple-icons:vim' },
			{ name: 'Figma', rating: 1, icon: 'simple-icons:figma' },
		]
	},
];

function stars(rating: number) {
	return '★'.repeat(rating) + '☆'.repeat(5 - rating);
}
---

<PageLayout
	title={`Stack | ${SITE_TITLE}`}
	description="Technologies and tools I've worked with, self-rated out of 5."
>
	<p class="eyebrow">~/stack</p>
	<h1>Stack</h1>
	<p class="intro">
		Technologies I've worked with, self-rated out of 5. I'd rather be honest than generous here.
	</p>

	{stack.map(({ category, items }) => (
		<div class="category">
			<h2>{category}</h2>
			<ul class="skill-list">
				{items.map(({ name, rating, icon }) => (
					<li>
						<span class="skill-name">
							<Icon name={icon} class="skill-icon" />
							{name}
						</span>
						<span class="stars" aria-label={`${rating} out of 5`}>
							{stars(rating).split('').map((s) => (
								<span class={s === '★' ? 'star filled' : 'star'}>{s}</span>
							))}
						</span>
					</li>
				))}
			</ul>
		</div>
	))}

	<style>
		.eyebrow {
			font-family: var(--font-mono);
			color: var(--accent);
			font-size: 0.85rem;
			margin-bottom: 0.4rem;
			margin-top: 0;
		}
		.intro {
			color: var(--text-muted);
			margin-bottom: 2rem;
			max-width: 38rem;
		}
		.category {
			margin-bottom: 2rem;
		}
		.category h2 {
			font-size: 0.78rem;
			text-transform: uppercase;
			letter-spacing: 0.1em;
			color: var(--text-muted);
			font-weight: 400;
			margin-bottom: 0.75rem;
		}
		.category h2::before {
			content: '# ';
			color: var(--accent);
		}
		.skill-list {
			list-style: none;
			padding: 0;
			margin: 0;
			display: grid;
			grid-template-columns: repeat(2, 1fr);
			gap: 0.45rem 2rem;
		}
		.skill-list li {
			display: flex;
			align-items: center;
			justify-content: space-between;
			border-bottom: 1px solid var(--border);
			padding-bottom: 0.35rem;
		}
		.skill-name {
			display: flex;
			align-items: center;
			gap: 0.4em;
			font-size: 0.9rem;
			color: var(--text);
		}
		.skill-icon {
			width: 1em;
			height: 1em;
			flex-shrink: 0;
			color: var(--text-muted);
		}
		.stars {
			display: flex;
			gap: 0.1em;
			flex-shrink: 0;
		}
		.star {
			font-size: 0.9rem;
			color: var(--border);
		}
		.star.filled {
			color: var(--accent);
		}
		@media (max-width: 520px) {
			.skill-list {
				grid-template-columns: 1fr;
			}
		}
	</style>
</PageLayout>
