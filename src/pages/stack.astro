---
import PageLayout from '../layouts/PageLayout.astro';
import { SITE_TITLE } from '../consts';

const stack = [
	{
		category: 'Systems & Infrastructure',
		items: [
			{ name: 'C/C++', rating: 4 },
			{ name: 'Rust', rating: 3 },
			{ name: 'Distributed systems', rating: 3 },
			{ name: 'Linux', rating: 4 },
			{ name: 'Docker', rating: 3 },
			{ name: 'Bash', rating: 3 },
			{ name: 'Kubernetes', rating: 2 },
			{ name: 'AWS', rating: 3 },
		]
	},
	{
		category: 'Game Dev',
		items: [
			{ name: 'Game engine architecture', rating: 3 },
			{ name: 'Graphics programming', rating: 3 },
			{ name: 'OpenGL', rating: 1 },
			{ name: 'SDL2', rating: 3 },
			{ name: 'SDL3', rating: 3 },
			{ name: 'GLM', rating: 3 },
			{ name: 'Lua', rating: 3 },
			{ name: 'Sol2', rating: 3 },
		]
	},
	{
		category: 'Web & Backend',
		items: [
			{ name: 'HTML / CSS', rating: 4 },
			{ name: 'JavaScript', rating: 3 },
			{ name: 'Node.js / Express', rating: 3 },
			{ name: 'Golang', rating: 2 },
			{ name: 'Zod', rating: 2 },
		]
	},
	{
		category: 'Databases',
		items: [
			{ name: 'MongoDB', rating: 4 },
			{ name: 'Redis', rating: 3 },
			{ name: 'PostgreSQL', rating: 3 },
			{ name: 'MariaDB', rating: 3 },
			{ name: 'Neo4j', rating: 2 },
			{ name: 'ChromaDB', rating: 2 },
			{ name: 'Cassandra', rating: 2 },
		]
	},
	{
		category: 'Data & ML',
		items: [
			{ name: 'Python', rating: 4 },
			{ name: 'Pandas / Matplotlib / Seaborn', rating: 4 },
			{ name: 'Keras / TensorFlow', rating: 3 },
			{ name: 'scikit-learn', rating: 3 },
			{ name: 'Spark / Scala', rating: 3 },
			{ name: 'Plotly / ipywidgets', rating: 3 },
			{ name: 'BeautifulSoup / Selenium', rating: 2 },
		]
	},
	{
		category: 'Tools & Workflow',
		items: [
			{ name: 'Git', rating: 4 },
			{ name: 'LaTeX', rating: 4 },
			{ name: 'Vim', rating: 3 },
			{ name: 'CMake', rating: 3 },
			{ name: 'DaVinci Resolve / After Effects', rating: 3 },
			{ name: 'Figma', rating: 1 },
		]
	},
];

function stars(rating: number) {
	return '★'.repeat(rating) + '☆'.repeat(5 - rating);
}
---

<PageLayout
	title={`Stack | ${SITE_TITLE}`}
	description="Technologies and tools I've worked with, self-rated out of 5."
>
	<p class="eyebrow">~/stack</p>
	<h1>Stack</h1>
	<p class="intro">
		Technologies I've worked with, self-rated out of 5. I'd rather be honest than generous here.
	</p>

	{stack.map(({ category, items }) => (
		<div class="category">
			<h2>{category}</h2>
			<ul class="skill-list">
				{items.map(({ name, rating }) => (
					<li>
						<span class="skill-name">{name}</span>
						<span class="stars" aria-label={`${rating} out of 5`}>
							{stars(rating).split('').map((s) => (
								<span class={s === '★' ? 'star filled' : 'star'}>{s}</span>
							))}
						</span>
					</li>
				))}
			</ul>
		</div>
	))}

	<style>
		.eyebrow {
			font-family: var(--font-mono);
			color: var(--accent);
			font-size: 0.85rem;
			margin-bottom: 0.4rem;
			margin-top: 0;
		}
		.intro {
			color: var(--text-muted);
			margin-bottom: 2rem;
			max-width: 38rem;
		}
		.category {
			margin-bottom: 2rem;
		}
		.category h2 {
			font-size: 0.78rem;
			text-transform: uppercase;
			letter-spacing: 0.1em;
			color: var(--text-muted);
			font-weight: 400;
			margin-bottom: 0.75rem;
		}
		.category h2::before {
			content: '# ';
			color: var(--accent);
		}
		.skill-list {
			list-style: none;
			padding: 0;
			margin: 0;
			display: grid;
			grid-template-columns: repeat(2, 1fr);
			gap: 0.45rem 2rem;
		}
		.skill-list li {
			display: flex;
			align-items: center;
			justify-content: space-between;
			border-bottom: 1px solid var(--border);
			padding-bottom: 0.35rem;
		}
		.skill-name {
			font-size: 0.9rem;
			color: var(--text);
		}
		.stars {
			display: flex;
			gap: 0.1em;
			flex-shrink: 0;
		}
		.star {
			font-size: 0.9rem;
			color: var(--border);
		}
		.star.filled {
			color: var(--accent);
		}
		@media (max-width: 520px) {
			.skill-list {
				grid-template-columns: 1fr;
			}
		}
	</style>
</PageLayout>
