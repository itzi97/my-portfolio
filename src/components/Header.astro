---
import { SITE_AUTHOR, GITHUB_URL, LINKEDIN_URL } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<a href="/" class="site-title">{SITE_AUTHOR}<span class="cursor"></span></a>
		<div class="nav-links">
			<HeaderLink href="/">~/home</HeaderLink>
			<HeaderLink href="/about">~/about</HeaderLink>
			<HeaderLink href="/projects">~/projects</HeaderLink>
			<a href={GITHUB_URL} target="_blank" rel="noopener" class="external">github ↗</a>
			<a href={LINKEDIN_URL} target="_blank" rel="noopener" class="external">linkedin ↗</a>
		</div>
	</nav>
</header>

<style>
	header {
		position: sticky;
		top: 0;
		z-index: 100;
		background: rgba(17, 17, 17, 0.95);
		border-bottom: 1px solid var(--border);
		backdrop-filter: blur(8px);
		-webkit-backdrop-filter: blur(8px);
		padding: 0 1.5em;
	}
	nav {
		max-width: 760px;
		margin: auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		height: 52px;
	}
	.site-title {
		font-family: var(--font-mono);
		font-size: 0.88em;
		color: var(--accent);
		text-decoration: none;
		font-weight: 600;
		letter-spacing: -0.01em;
	}
	.nav-links {
		display: flex;
		gap: 1.5em;
		align-items: center;
	}
	.nav-links a {
		font-size: 0.82em;
		color: var(--text-muted);
		text-decoration: none;
		transition: color 0.15s ease;
		letter-spacing: 0.01em;
	}
	.nav-links a:hover,
	.nav-links a.active {
		color: var(--accent);
		text-decoration: none;
	}
	.external {
		font-size: 0.78em !important;
		color: var(--text-muted) !important;
	}
	.external:hover {
		color: var(--accent) !important;
	}
	@media (max-width: 600px) {
		.external { display: none; }
		.nav-links { gap: 1em; }
	}
</style>
