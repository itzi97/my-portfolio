---
import { SITE_AUTHOR, GITHUB_URL, LINKEDIN_URL, KAGGLE_URL, EMAIL } from '../consts';
import { Icon } from 'astro-icon/components';
const today = new Date();
---

<footer>
	<div class="footer-inner">
		<span class="muted">// {SITE_AUTHOR} &mdash; {today.getFullYear()}</span>
		<div class="footer-icons">
			<a href={GITHUB_URL} target="_blank" rel="noopener" aria-label="GitHub">
				<Icon name="simple-icons:github" class="footer-icon" />
			</a>
			<a href={LINKEDIN_URL} target="_blank" rel="noopener" aria-label="LinkedIn">
				<Icon name="simple-icons:linkedin" class="footer-icon" />
			</a>
			<a href={KAGGLE_URL} target="_blank" rel="noopener" class="kaggle-link">kg</a>
			<a href={`mailto:${EMAIL}`} aria-label="Email">
				<Icon name="lucide:mail" class="footer-icon" />
			</a>
		</div>
	</div>
</footer>

<style>
	footer {
		border-top: 1px solid var(--border);
		padding: 1.5em 1.5em;
		margin-top: 4em;
	}
	.footer-inner {
		max-width: 760px;
		margin: auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		flex-wrap: wrap;
		gap: 0.75em;
	}
	.muted {
		font-size: 0.78em;
		color: var(--text-muted);
	}
	.footer-icons {
		display: flex;
		gap: 1.1em;
		align-items: center;
	}
	.footer-icon {
		width: 1.1em;
		height: 1.1em;
		display: block;
		color: var(--text-muted);
		transition: color 0.15s ease;
	}
	.footer-icons a:hover .footer-icon {
		color: var(--accent);
	}
	.kaggle-link {
		font-family: var(--font-mono);
		font-size: 0.78em;
		font-weight: 600;
		color: var(--text-muted);
		text-decoration: none;
		transition: color 0.15s ease;
		letter-spacing: 0.02em;
	}
	.kaggle-link:hover {
		color: var(--accent);
	}
</style>
